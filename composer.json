{
    "name": "operis/app",
    "description": "Operis writer management platform",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "aws/aws-sdk-php": "^3.0",
        "phpmailer/phpmailer": "^6.9"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        },
        "files": [
            "shared-functions.php"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
